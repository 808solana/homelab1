# ── Auth secrets ───────────────────────────────────────────────────────────
# ADMIN_TOKEN protects /admin/* — compare via constant-time comparison.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# JWT_SECRET signs/verifies user session tokens for the luv13 website.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── Browser login for /admin/* (optional) ───────────────────────────────────
# Lets you access /admin/summary from any browser at /admin/login.
# If unset, only the X-Admin-Token header (ADMIN_TOKEN above) works.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_SESSION_TTL_DAYS=7

# ── Optional tunables (defaults shown) ─────────────────────────────────────
# NEURALWATT_BASE_URL=https://api.neuralwatt.com/v1
# Flat-rate revenue: $0.23 per million tokens on every token (input/output/cached).
# YOUR_INPUT_PRICE_PER_M=0.23
# YOUR_OUTPUT_PRICE_PER_M=0.23
# YOUR_CACHED_INPUT_PRICE_PER_M=0.23
# Blended upstream cost fallback ($/M) when response omits cost.
# BLENDED_COST_PER_M=0.10
# MAX_KEYS_PER_CUSTOMER=5

# ── Concurrency-slot router (replaces time-based cooldowns) ─────────────────
# Hard cap of concurrent in-flight requests per Neuralwatt account.
# PROXY_ACCOUNT_MAX_CONCURRENCY=3
# Park duration after a genuine auth/budget error (401/402/403) — the only
# long-duration account removal left. 429s never blacklist.
# PROXY_BUDGET_COOLDOWN=300
# Breather after a 5xx/connection error (seconds).
# PROXY_ERROR_PAUSE=1.0
# Jitter window before retrying after an unexpected 429 (seconds).
# PROXY_429_RETRY_WAIT_MIN=0.2
# PROXY_429_RETRY_WAIT_MAX=0.5
# How long the local counter reads "full" after an unexpected 429 (ms).
# PROXY_429_SYNC_TTL_MS=1000
# How often the in-flight sampler logs per-account slot counts (seconds).
# PROXY_INFLIGHT_LOG_INTERVAL=5
