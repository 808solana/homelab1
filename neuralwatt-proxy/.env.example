# ── Auth secrets ───────────────────────────────────────────────────────────
# ADMIN_TOKEN protects /admin/* — compare via constant-time comparison.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# JWT_SECRET signs/verifies user session tokens for the luv13 website.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ── Browser login for /admin/* (optional) ───────────────────────────────────
# Lets you access /admin/summary from any browser at /admin/login.
# If unset, only the X-Admin-Token header (ADMIN_TOKEN above) works.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# ADMIN_SESSION_TTL_DAYS=7

# ── Optional tunables (defaults shown) ─────────────────────────────────────
# NEURALWATT_BASE_URL=https://api.neuralwatt.com/v1
# Flat-rate revenue: $0.23 per million tokens on every token (input/output/cached).
# YOUR_INPUT_PRICE_PER_M=0.23
# YOUR_OUTPUT_PRICE_PER_M=0.23
# YOUR_CACHED_INPUT_PRICE_PER_M=0.23
# Blended upstream cost fallback ($/M) when response omits cost.
# BLENDED_COST_PER_M=0.10
# MAX_KEYS_PER_CUSTOMER=5
# PROXY_MAX_RETRIES=5
# PROXY_MAX_BACKOFF=30
# PROXY_ACCOUNT_COOLDOWN=3
# PROXY_BUDGET_COOLDOWN=300
